# PostgreSQL
DATABASE_URL=postgresql://youruser@localhost:5432/sonar

# JWT
JWT_SECRET_KEY=change-me-to-a-real-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO

# ── AI Emotion Analysis (fallback: NVIDIA NIM → Groq → Together AI) ──
# At least ONE key is required for mood analysis to work.
# NVIDIA NIM (PRIMARY): https://build.nvidia.com/
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key
# Groq (SECONDARY): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Together AI (LAST RESORT): https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-api-key

# ── Spotify (REQUIRED for playlist generation) ──
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
